PORT=6000
NODE_ENV=development
MONGO_ATLAS_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=registerd_types
CRON_SECRET=<generate-a-long-random-secret>
CLIENT_ONBOARDING_REMINDERS_ENABLED=true
CCP_API_URL=http://localhost:8081
CCP_API_KEY=
CCP_SHARED_API_KEY=
CLIENT_ORIGIN=http://localhost:6173
APP_URL=http://localhost:6173
CCP_API_BASE_URL=http://localhost:8081/api
CCP_FRONTEND_URL=http://localhost:8081
CCP_FETCH_TIMEOUT_MS=15000
# Optional: set this and send x-ccp-secret from CCP when fetching CRM users.
CCP_SHARED_SECRET=
# Optional: CRM will POST created/updated users here so CCP can upsert them.
CCP_USER_SYNC_URL=http://localhost:8081/api/crm/users/sync
CCP_TEAM_SYNC_URL=http://localhost:8081/api/crm/teams/sync
CCP_NOTIFICATION_SYNC_URL=http://localhost:8081/api/crm/notifications/sync
# Production CCP URLs:
# CCP_API_BASE_URL=https://ccp-62b2.onrender.com/api
# CCP_FRONTEND_URL=https://ccp-henna.vercel.app
# CCP_USER_SYNC_URL=https://ccp-62b2.onrender.com/api/crm/users/sync
# CCP_TEAM_SYNC_URL=https://ccp-62b2.onrender.com/api/crm/teams/sync
# CCP_NOTIFICATION_SYNC_URL=https://ccp-62b2.onrender.com/api/crm/notifications/sync
# Set true only if CCP needs the initial password during user creation.
CCP_SYNC_PASSWORD=false
PYTHON_COMMAND=python
JWT_SECRET=change-this-long-random-secret
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
OTP_EMAILS_ENABLED=true
MAIL_USER=your-brevo-smtp-login
MAIL_PASS=your-brevo-smtp-key
# Keep false for Brevo SMTP keys; set true only for Gmail App Passwords copied with spaces.
MAIL_PASS_STRIP_SPACES=false
MAIL_FROM_NAME=CRM
MAIL_FROM="CRM <your-verified-brevo-sender@example.com>"
MAIL_REPLY_TO=your-reply-to-email@example.com
MAIL_BRAND_NAME=ANANT TATTVA
MAIL_LOGO_URL=https://crm.ananttattva.com/assets/at-logo-CTH78yrR.svg
PENDING_APPROVAL_EMAILS_ENABLED=false
PENDING_APPROVAL_EMAIL_START_AT=
PENDING_APPROVAL_MAX_REMINDERS=1
ADMIN_EMAILS=admin1@example.com,admin2@example.com
PENDING_APPROVAL_EMAILS=
ADMIN_NAME=System Admin
ADMIN_EMAIL=krishnaerrorr@gmail.com
ADMIN_PASSWORD=Admin@123456
ADMIN_SYNC_PASSWORD=true
